{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Generate Unit Test (Single File)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["${input:cppFilePath}"],
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal"
        },
        {
            "name": "Generate Unit Tests (Batch from Config)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["--config", "${input:configPath}"],
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal"
        }
    ],
    "inputs": [
        {
            "id": "cppFilePath",
            "type": "promptString",
            "description": "Path to the C++ source file to generate tests for",
            "default": "path/to/your/file.cpp"
        },
        {
            "id": "configPath",
            "type": "promptString",
            "description": "Path to the JSON config file listing files to test",
            "default": "utest_config.json"
        }
    ]
}
